        h.proxy.unblock();

        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 75)));

    test('server freeze', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // See comment in fast version for why we close proxy connections
