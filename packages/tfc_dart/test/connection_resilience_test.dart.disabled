      }
    }, timeout: const Timeout(Duration(seconds: 60)));

    test('network cable flaky', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        h.proxy.flaky(
          blockDuration: const Duration(seconds: 2),
          forwardDuration: const Duration(milliseconds: 500),
        );
