        await Future.delayed(const Duration(seconds: 15));
        h.unfreezeServer();
        await Future.delayed(const Duration(milliseconds: 100));
        h._closeProxyConnections();

        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 60)));

    test('server restart', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Kill server, wait 15s, restart with new value
        await h.killServer();
        await Future.delayed(const Duration(seconds: 15));
        await h.startServer(value: 55.55);

        await h.assertRecovery(expectedValue: 55.55);
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 75)));

    test('server slow', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        h.proxy.slow(const Duration(seconds: 3));
        await Future.delayed(const Duration(seconds: 15));
        h.proxy.unblock();

        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 60)));
  });

  // =========================================================================
  // EDGE CASES
  // =========================================================================
  group('Edge cases', () {
    test('rapid reconnection cycling', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // 10 rapid kill/restart cycles
        for (int i = 0; i < 10; i++) {
          final newValue = 30.0 + i;
          await h.restartServer(newValue: newValue);
          // Very short gap between cycles
          await Future.delayed(const Duration(milliseconds: 500));
          print('  Cycle $i: restarted with value=$newValue, '
              'total values=${h.values.length}');
        }

        // Wait for things to stabilize, then force a clean reconnection.
        // During rapid cycling, the resubscription from cycle N may not
        // complete before cycle N+1 kills the server.  After all cycles,
        // closing proxy connections forces one final clean reconnection
        // which triggers a fresh session → resubscribe.
        await Future.delayed(const Duration(seconds: 2));
        h._closeProxyConnections();
        await h.assertRecovery(expectedValue: 39.0);
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 90)));

    test('value change during disconnection', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Simulate: client loses network, then the server restarts with
        // a different value (e.g. PLC reboots with new config).
        // Using server restart rather than just Server.write() because
        // OPC UA session recovery on the same server preserves the
        // subscription but lost publish notifications are NOT re-sent.
        // A server restart guarantees session loss → resubscription →
        // the client gets the CURRENT value, not a stale cached one.
        h.proxy.block();
        await Future.delayed(const Duration(seconds: 2));

        // Server restarts with new value while client is disconnected.
        // killServer() closes proxy connections (TCP RST to client),
        // so the client detects the disconnect immediately.
        // New proxy connections default to forwarding mode, so the
        // client reconnects through the proxy once the server is back.
        await h.killServer();
        await Future.delayed(const Duration(milliseconds: 500));

        // Capture value count BEFORE starting server, so assertRecovery
        // catches the 99.99 that arrives after the client reconnects.
        final countBefore = h.values.length;
        await h.startServer(value: 99.99);

        // Wait for the expected value to arrive
        final deadline = DateTime.now().add(const Duration(seconds: 30));
        while (!h.values.skip(countBefore).any((v) => v.$2 == 99.99)) {
          if (DateTime.now().isAfter(deadline)) {
            final recent = h.values.skip(countBefore).map((v) => v.$2).toList();
            fail('Expected value 99.99 not received after server restart. '
                'Values since restart: $recent');
          }
          await Future.delayed(const Duration(milliseconds: 200));
        }
        print('Harness: received 99.99 after recovery');

        // Verify no flood of stale values
        final staleCount = h.values
            .skip(countBefore)
            .where((v) => v.$2 == TestHarness._initialValue)
            .length;
        expect(staleCount, lessThanOrEqualTo(2),
            reason: 'Stale value flood: ${TestHarness._initialValue} '
                'appeared $staleCount times after server changed to 99.99');
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 45)));

    test('disconnect during subscription setup', () async {
      // Create harness but DON'T subscribe yet
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();

        // Block network immediately before subscribing
        h.proxy.block();

        // Start subscription (will be stuck connecting/retrying)
        unawaited(h.subscribe());

        // Wait a bit, then unblock
        await Future.delayed(const Duration(seconds: 3));
        h.proxy.unblock();

        // Subscription should eventually succeed
        await h.waitForFirstValue(timeout: const Duration(seconds: 20));
        expect(h.values, isNotEmpty,
            reason: 'Subscription should succeed after network recovers');
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 45)));

    test('multiple sequential disruptions', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // 3 cycles of block -> unblock -> verify recovery
        for (int cycle = 0; cycle < 3; cycle++) {
          print('\n--- Disruption cycle $cycle ---');
          final countBefore = h.values.length;

          h.proxy.block();
          await Future.delayed(const Duration(seconds: 5));
          h.proxy.unblock();

          await h.assertRecovery();

          // Verify new values arrived in this cycle
          expect(h.values.length, greaterThan(countBefore),
              reason: 'Cycle $cycle: values should flow after recovery');

          // Brief stable period before next disruption
          await Future.delayed(const Duration(seconds: 2));
        }
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 90)));

    test('server restart with missing node', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Kill server, restart WITHOUT the monitored node
        await h.killServer();
        await Future.delayed(const Duration(seconds: 1));
        await h.startServerWithoutNode();

        // StateMan should handle this gracefully (no crash)
        // Connection may come back but subscription will fail to re-establish
        await Future.delayed(const Duration(seconds: 10));

        // Now restart with the node present
        await h.killServer();
        await Future.delayed(const Duration(seconds: 1));
        await h.startServer(value: 77.77);

        // Should eventually recover
        await h.assertRecovery(
            expectedValue: 77.77,
            timeout: const Duration(seconds: 30));
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 75)));

    test('write during disconnection', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Block network
        h.proxy.block();
        await Future.delayed(const Duration(seconds: 2));

        // Try to write while disconnected - should fail or timeout, not hang
        try {
          await h.stateMan
              .write(
                'weight',
                DynamicValue(
                    value: 42.0,
                    typeId: NodeId.double,
                    name: 'weight'),
              )
              .timeout(const Duration(seconds: 10));
        } catch (e) {
          print('Write during disconnection failed (expected): $e');
        }

        // Unblock and verify recovery
        h.proxy.unblock();
        await h.assertRecovery();

        // Write should work after recovery
        await h.stateMan
            .write(
              'weight',
              DynamicValue(
                  value: 42.0,
                  typeId: NodeId.double,
                  name: 'weight'),
            )
            .timeout(const Duration(seconds: 10));
        print('Write after recovery succeeded');
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 60)));

    test('gradual degradation', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
          serverPort: p.$1, proxyPort: p.$2);
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Phase 1: Slow (still works, just laggy)
        print('\n--- Phase 1: slow ---');
        h.proxy.slow(const Duration(seconds: 1));
        await Future.delayed(const Duration(seconds: 3));

        // Phase 2: Slower
        print('\n--- Phase 2: slower ---');
        h.proxy.slow(const Duration(seconds: 3));
        await Future.delayed(const Duration(seconds: 5));

        // Phase 3: Flaky (intermittent)
        print('\n--- Phase 3: flaky ---');
        h.proxy.flaky(
          blockDuration: const Duration(seconds: 2),
          forwardDuration: const Duration(milliseconds: 500),
        );
        await Future.delayed(const Duration(seconds: 5));

        // Phase 4: Full blackout
        print('\n--- Phase 4: blackout ---');
        h.proxy.block();
        await Future.delayed(const Duration(seconds: 5));

        // Phase 5: Recovery
        print('\n--- Phase 5: recovery ---');
        h.proxy.unblock();
        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 60)));
  });

  // =========================================================================
  // BEYOND IDLE TIMEOUT (subscription stream closes after idle period)
  // =========================================================================
  group('Beyond idle timeout', () {
    // Use a very short idle timeout (1s) so tests don't take forever.
    // Disruption lasts longer than idle timeout to trigger stream disposal.

    test('network cable disconnected beyond idle timeout', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
        serverPort: p.$1,
        proxyPort: p.$2,
        idleTimeout: const Duration(seconds: 1),
      );
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Block for longer than the idle timeout
        h.proxy.block();
        await Future.delayed(const Duration(seconds: 3));
        h.proxy.unblock();

        // StateMan should recover even though the AutoDisposingStream
        // may have fired its idle timer during the disruption
        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 45)));

    test('server freeze beyond idle timeout', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
        serverPort: p.$1,
        proxyPort: p.$2,
        idleTimeout: const Duration(seconds: 1),
      );
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // See comment in fast version for why we close proxy connections
        h.freezeServer();
        await Future.delayed(const Duration(seconds: 3));
        h.unfreezeServer();
        await Future.delayed(const Duration(milliseconds: 100));
        h._closeProxyConnections();

        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 45)));

    test('server restart beyond idle timeout', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
        serverPort: p.$1,
        proxyPort: p.$2,
        idleTimeout: const Duration(seconds: 1),
      );
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        await h.killServer();
        await Future.delayed(const Duration(seconds: 3));
        await h.startServer(value: 88.88);

        await h.assertRecovery(expectedValue: 88.88);
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 45)));

    test('multiple disruptions each exceeding idle timeout', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
        serverPort: p.$1,
        proxyPort: p.$2,
        idleTimeout: const Duration(seconds: 1),
      );
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        for (int cycle = 0; cycle < 3; cycle++) {
          print('\n--- Idle timeout cycle $cycle ---');
          final newValue = 30.0 + cycle;

          // Kill server → disruption exceeds idle timeout (1s)
          await h.killServer();
          await Future.delayed(const Duration(seconds: 3));
          await h.startServer(value: newValue);

          // Server restart guarantees session loss → resubscription.
          await h.assertRecovery(expectedValue: newValue);
          await Future.delayed(const Duration(seconds: 2));
        }
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 90)));

    // NOTE: This test is last in the group because flaky mode can leave
    // stray socket errors that pollute subsequent tests' zones.
    test('flaky connection beyond idle timeout', () async {
      final p = nextPorts();
      final h = await TestHarness.create(
        serverPort: p.$1,
        proxyPort: p.$2,
        idleTimeout: const Duration(seconds: 1),
      );
      try {
        await h.waitForConnection();
        await h.subscribe();
        await h.waitForFirstValue();

        // Use longer forward window (1s) to let complete OPC UA messages
        // through. Shorter windows (200ms) corrupt messages mid-flight,
        // killing the client isolate irreversibly.
        h.proxy.flaky(
          blockDuration: const Duration(seconds: 1),
          forwardDuration: const Duration(seconds: 1),
        );
        await Future.delayed(const Duration(seconds: 5));
        h.proxy.unblock();
        // Force TCP RST so the client does a clean reconnection
        // instead of trying to use a corrupted SecureChannel.
        h._closeProxyConnections();

        await h.assertRecovery();
      } finally {
        await h.dispose();
      }
    }, timeout: const Timeout(Duration(seconds: 45)));
  });

  // =========================================================================
  // OPEN62541 VERSION GATE
  // =========================================================================
  group('open62541 version gate', () {
    test('unknown RequestId should not kill SecureChannel', () async {
      final nodeId = NodeId.fromString(1, 'Test.Weight');

      final server = Server(
        port: inspectServerPort,
        logLevel: LogLevel.UA_LOGLEVEL_INFO,
      );
      server.addVariableNode(
        nodeId,
        DynamicValue(value: 22.81, typeId: NodeId.double, name: 'Weight'),
        accessLevel: const AccessLevelMask(read: true, write: true),
      );
      server.start();

      bool serverRunning = true;
      unawaited(() async {
        while (serverRunning && server.runIterate(waitInterval: false)) {
          await Future.delayed(const Duration(milliseconds: 5));
        }
      }());

      final proxy = InspectingProxy(
          listenPort: inspectProxyPort, targetPort: inspectServerPort);
      await proxy.start();

      final client = Client(
        logLevel: LogLevel.UA_LOGLEVEL_INFO,
        secureChannelLifeTime: const Duration(seconds: 10),
        connectivityCheckInterval: const Duration(seconds: 2),
      );

      bool keepIterating = true;
      unawaited(() async {
        while (keepIterating) {
          client.runIterate(const Duration(milliseconds: 10));
          await Future.delayed(const Duration(milliseconds: 10));
        }
      }());

      client.connect('opc.tcp://127.0.0.1:$inspectProxyPort');

      await client.stateStream
          .firstWhere((s) =>
              s.channelState ==
                  SecureChannelState.UA_SECURECHANNELSTATE_OPEN &&
              s.sessionState == SessionState.UA_SESSIONSTATE_ACTIVATED)
          .timeout(const Duration(seconds: 10));

      final subId = await client.subscriptionCreate(
        requestedPublishingInterval: const Duration(milliseconds: 100),
        requestedMaxKeepAliveCount: 500,
      );
      client.monitor(nodeId, subId,
          samplingInterval: const Duration(milliseconds: 100));

      // Let traffic flow so proxy can learn channel context
      await Future.delayed(const Duration(seconds: 2));

      expect(proxy.channelId, isNotNull,
          reason: 'Proxy should have captured ChannelId');
      expect(proxy.tokenId, isNotNull,
          reason: 'Proxy should have captured TokenId');

      bool channelLeftOpen = false;
      final stateSub = client.stateStream.listen((state) {
        if (state.channelState !=
            SecureChannelState.UA_SECURECHANNELSTATE_OPEN) {
          channelLeftOpen = true;
        }
      });

      proxy.blockServerToClient();
      await Future.delayed(const Duration(milliseconds: 200));

      // Inject MSG with bogus RequestId
      proxy.injectBogusMsg(requestId: 99999);
      await Future.delayed(const Duration(seconds: 2));

      if (channelLeftOpen) {
        print('BUG: Channel killed by unknown RequestId. '
            'open62541 v1.5.0-rc1 returns BadSecurityChecksFailed. '
            'Upgrade to v1.5.2+.');
      }

      expect(channelLeftOpen, isFalse,
          reason: 'SecureChannel should survive unknown RequestId. '
              'open62541 v1.5.0-rc1 returns BadSecurityChecksFailed '
              'in processMSGResponse. Fixed in v1.5.2+.');

      await stateSub.cancel();
      keepIterating = false;
      await proxy.stop();
      serverRunning = false;
      server.shutdown();
      client.disconnect();
      client.delete();
      server.delete();
    }, timeout: const Timeout(Duration(seconds: 30)));
  });
}
